# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Spotify ───────────────────────────────────────────────────────────────────
# From your Spotify developer dashboard: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ── PostgreSQL (RDS) ──────────────────────────────────────────────────────────
# After `terraform apply`, grab the RDS endpoint from the output: terraform output rds_endpoint
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=spotify_analytics
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Full DSN string — used by RDSLoader (combines the values above)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:your_db_password_here@your-rds-endpoint.rds.amazonaws.com:5432/spotify_analytics

# ── AWS ───────────────────────────────────────────────────────────────────────
# After `terraform apply`, grab the bucket name: terraform output s3_bucket_name
S3_BUCKET=spotify-analytics-your-account-id

# Region your infrastructure is deployed in
AWS_REGION=us-east-1

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create an incoming webhook in your Slack workspace:
# Slack App settings → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── dbt ───────────────────────────────────────────────────────────────────────
# These are referenced in dbt/profiles.yml.example — dbt reads them at runtime
DBT_DB_HOST=your-rds-endpoint.rds.amazonaws.com
DBT_DB_USER=postgres
DBT_DB_PASSWORD=your_db_password_here
